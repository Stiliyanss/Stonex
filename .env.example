# Server Configuration
PORT=3001
NODE_ENV=development

# Email Configuration - Choose ONE method below

# Method 1: Gmail with App Password (Recommended)
# 1. Enable 2FA on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below (no spaces)
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-16-char-app-password

# Method 2: Custom SMTP Server (e.g., SendGrid, Mailgun, AWS SES)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password

# Where to send admin notifications
ADMIN_EMAIL=your-email@gmail.com

# Uncomment the method you want to use by removing the comment from those lines
# and commenting out the other method's lines
